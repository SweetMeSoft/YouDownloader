<Window x:Class="YouDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="YouDownloader"
        WindowState="Maximized"
        Background="#0B0F19">
    <Window.Resources>
        <!-- Icon Style -->
        <Style x:Key="IconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#6366F1" />
        </Style>

        <!-- Base Label Style -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#F9FAFB" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Modern Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#6366F1" />
            <Setter Property="Foreground" Value="#F9FAFB" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4F46E5" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4338CA" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#1F2937" />
                                <Setter Property="Foreground" Value="#9CA3AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1F2937" />
            <Setter Property="Foreground" Value="#F9FAFB" />
            <Setter Property="BorderBrush" Value="#374151" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="CaretBrush" Value="#F9FAFB" />
            <Setter Property="SelectionBrush" Value="#818CF8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4B5563" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#111827" />
                                <Setter Property="Foreground" Value="#9CA3AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Border x:Name="checkboxBorder" 
                                        Width="18" 
                                        Height="18" 
                                        CornerRadius="4" 
                                        Background="#1F2937" 
                                        BorderBrush="#374151" 
                                        BorderThickness="1.5">
                                    <Grid>
                                        <Path x:Name="checkmark" 
                                              Data="M 3,8 L 7,12 L 15,4" 
                                              Stroke="#F9FAFB" 
                                              StrokeThickness="2" 
                                              StrokeStartLineCap="Round" 
                                              StrokeEndLineCap="Round" 
                                              StrokeLineJoin="Round"
                                              Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              RecognizesAccessKey="True"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkboxBorder" Property="Background" Value="#6366F1" />
                                <Setter TargetName="checkboxBorder" Property="BorderBrush" Value="#6366F1" />
                                <Setter TargetName="checkmark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkboxBorder" Property="BorderBrush" Value="#818CF8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="checkboxBorder" Property="Background" Value="#111827" />
                                <Setter TargetName="checkboxBorder" Property="BorderBrush" Value="#374151" />
                                <Setter Property="Foreground" Value="#9CA3AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ProgressBar Style -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#1F2937" />
            <Setter Property="Foreground" Value="#10B981" />
            <Setter Property="BorderBrush" Value="#374151" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="12" />
        </Style>
    </Window.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <!-- Row 0: Header & Input -->
            <RowDefinition Height="Auto" />
            <!-- Row 1: Options -->
            <RowDefinition Height="Auto" />
            <!-- Row 2: Workspace (Left details, Right queue) -->
            <RowDefinition Height="*" />
            <!-- Row 3: Progress & Action -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ROW 0: Header & Link Input -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock FontFamily="Segoe MDL2 Assets" 
                           Text="&#xE896;" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="#6366F1" 
                           VerticalAlignment="Center" 
                           Margin="0,0,12,0" />
                <TextBlock Text="YouDownloader" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#F9FAFB" 
                           VerticalAlignment="Center" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtLink" 
                         Height="40" 
                         VerticalContentAlignment="Center" 
                         Margin="0,0,12,0" />

                <Button x:Name="btnAdd" 
                        Grid.Column="1" 
                        Width="120" 
                        Height="40" 
                        Content="Add to Queue" 
                        Click="btnAdd_Click"/>
            </Grid>
        </Grid>

        <!-- ROW 1: Options Bar -->
        <Border Grid.Row="1" 
                Background="#111827" 
                BorderBrush="#1F2937" 
                BorderThickness="1" 
                CornerRadius="8" 
                Padding="16,12" 
                Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="OPTIONS" 
                           FontSize="11" 
                           FontWeight="Bold" 
                           Foreground="#9CA3AF" 
                           VerticalAlignment="Center" 
                           Margin="0,0,24,0" />

                <CheckBox x:Name="chkDownloadAudio"
                          IsChecked="True"
                          Margin="0,0,24,0"
                          Unchecked="chkDownloadAudio_Unchecked"
                          Checked="chkDownloadVideo_Checked">Audio</CheckBox>

                <CheckBox x:Name="chkDownloadVideo"
                          IsChecked="True"
                          Margin="0,0,24,0"
                          Unchecked="chkDownloadAudio_Unchecked"
                          Checked="chkDownloadVideo_Checked">Video</CheckBox>

                <CheckBox x:Name="chkMergeAudioVideo"
                          IsChecked="True"
                          Margin="0,0,24,0">Merge Audio &amp; Video</CheckBox>

                <CheckBox x:Name="chkDownloadSubtitles"
                          IsChecked="False"
                          Margin="0,0,24,0">Subtitles (ES)</CheckBox>

                <CheckBox x:Name="chkDownloadSummary"
                          IsChecked="False">Text Summary</CheckBox>
            </StackPanel>
        </Border>

        <!-- ROW 2: Workspace split -->
        <Grid Grid.Row="2" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <!-- Left: Active download details -->
                <ColumnDefinition Width="340" />
                <!-- Right: Scrollable Queue -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Active Download Card -->
            <Border Grid.Column="0" 
                    Background="#111827" 
                    BorderBrush="#1F2937" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="20" 
                    Margin="0,0,24,0"
                    VerticalAlignment="Top">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Style="{StaticResource IconStyle}" Text="&#xE896;" Foreground="#10B981" Margin="0,0,8,0" />
                        <TextBlock Text="Active Download" FontSize="14" FontWeight="Bold" Foreground="#F9FAFB" VerticalAlignment="Center" />
                    </StackPanel>

                    <Label Grid.Row="1" 
                           Name="lblDownloading" 
                           Content="No active download" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="#E5E7EB" 
                           Margin="0,0,0,20">
                        <Label.ContentTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </Label.ContentTemplate>
                    </Label>

                    <StackPanel Grid.Row="2" Orientation="Vertical">
                        <!-- Size -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource IconStyle}" Text="&#xE8A5;" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                <TextBlock Text="TOTAL SIZE" FontSize="9" FontWeight="Bold" Foreground="#9CA3AF" Margin="0,0,0,2" />
                                <Label Name="lblSize" Content="0 MB" FontSize="13" FontWeight="SemiBold" Foreground="#F9FAFB" />
                            </StackPanel>
                        </Grid>
                        <Border BorderBrush="#1F2937" BorderThickness="0,0,0,1" Margin="0,0,0,12" />

                        <!-- Downloaded -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource IconStyle}" Text="&#xE896;" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                <TextBlock Text="DOWNLOADED" FontSize="9" FontWeight="Bold" Foreground="#9CA3AF" Margin="0,0,0,2" />
                                <Label Name="lblDownloaded" Content="0 MB" FontSize="13" FontWeight="SemiBold" Foreground="#F9FAFB" />
                            </StackPanel>
                        </Grid>
                        <Border BorderBrush="#1F2937" BorderThickness="0,0,0,1" Margin="0,0,0,12" />

                        <!-- Speed -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource IconStyle}" Text="&#xF166;" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                <TextBlock Text="DOWNLOAD SPEED" FontSize="9" FontWeight="Bold" Foreground="#9CA3AF" Margin="0,0,0,2" />
                                <Label Name="lblSpeed" Content="0 KB/sec" FontSize="13" FontWeight="SemiBold" Foreground="#F9FAFB" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Download Queue -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="DOWNLOAD QUEUE" 
                           FontSize="12" 
                           FontWeight="Bold" 
                           Foreground="#9CA3AF" 
                           Margin="0,4,0,16" />

                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl Name="itcVideos" Padding="0,0,12,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#111827" 
                                        BorderBrush="#1F2937" 
                                        BorderThickness="1" 
                                        CornerRadius="8" 
                                        Padding="12" 
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Thumbnail -->
                                        <Border Grid.Column="0" CornerRadius="6" ClipToBounds="True" Margin="0,0,16,0" Background="#1F2937">
                                            <Image Height="68" Width="120" Source="{Binding UrlThumbnail}" Stretch="UniformToFill" />
                                        </Border>

                                        <!-- Meta -->
                                        <Grid Grid.Column="1" VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" 
                                                       Text="{Binding Title}" 
                                                       FontSize="13" 
                                                       FontWeight="SemiBold" 
                                                       Foreground="#F9FAFB" 
                                                       TextWrapping="Wrap" 
                                                       MaxHeight="40" 
                                                       TextTrimming="CharacterEllipsis" />

                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                                <TextBlock Style="{StaticResource IconStyle}" Text="&#xE8A5;" FontSize="11" Foreground="#9CA3AF" Margin="0,0,4,0" />
                                                <TextBlock Text="{Binding Size}" FontSize="12" Foreground="#9CA3AF" Margin="0,0,16,0" />

                                                <TextBlock Style="{StaticResource IconStyle}" Text="&#xE787;" FontSize="11" Foreground="#9CA3AF" Margin="0,0,4,0" />
                                                <TextBlock Text="{Binding Date}" FontSize="12" Foreground="#9CA3AF" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ROW 3: Progress & Download Action -->
        <Border Grid.Row="3" 
                BorderBrush="#1F2937" 
                BorderThickness="0,1,0,0" 
                Padding="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,24,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Label Name="lblProgress" 
                           Content="Waiting..." 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="#9CA3AF" 
                           Margin="0,0,0,8" />

                    <ProgressBar x:Name="prgDownload" 
                                 Grid.Row="1" 
                                 Height="10" />
                </Grid>

                <Button x:Name="btnDownload" 
                        Grid.Column="1" 
                        Width="160" 
                        Height="40" 
                        Content="Download Queue" 
                        Click="btnDownload_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
